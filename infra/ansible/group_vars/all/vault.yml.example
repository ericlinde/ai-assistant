# Copy this file to vault.yml and encrypt with: ansible-vault encrypt vault.yml
# Never commit the real vault.yml (it is gitignored via ansible/group_vars/all/vault.yml).
#
# Ansible Vault scope: secrets needed to reach and configure the server.
# Application runtime secrets live in Infisical Cloud (see .env.example).
# CI/CD secrets (HCLOUD_TOKEN, R2_*, SSH_PUBLIC_KEY etc.) live in GitHub Secrets.

# vault_ssh_private_key_path: ""  # path to deployer SSH private key on the Ansible host
#                                 # e.g. /home/user/.ssh/id_ed25519
# vault_infisical_token: ""       # Infisical machine identity token (written to /opt/agent/.token)
# vault_domain: ""                # e.g. agent.ejlinde.com  (also set in Infisical as DOMAIN)
# vault_admin_email: ""           # for Let's Encrypt certificate (also set in Infisical as ADMIN_EMAIL)
