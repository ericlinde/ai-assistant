# Secret names required in Infisical Cloud (prod environment).
# Empty value  = required in Infisical — add the secret there with its real value.
# Non-empty value = hardcoded constant — used directly, not stored in Infisical.
#
# To add secrets:  infisical secrets set KEY value
# To list secrets: infisical secrets --format=json
#
# HCLOUD_TOKEN is a GitHub Secret (CI/CD only — not in Infisical).

# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Linear ─────────────────────────────────────────────────────
LINEAR_API_KEY=
LINEAR_TEAM_ID=e96a084f-7033-4b61-be58-3fb1e6679a50
LINEAR_PROJECT_ID=4edee420-cd11-48be-90fb-01bd19f54a1f

# ── Gmail (OAuth2) ─────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Slack ──────────────────────────────────────────────────────
SLACK_BOT_TOKEN=

# ── Google Drive ───────────────────────────────────────────────
GDRIVE_AGENT_MEMORY_FILE_ID=
GDRIVE_NOTEBOOK_REGISTRY_FILE_ID=
GDRIVE_SERVICE_ACCOUNT_JSON=

# ── n8n ────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_PASSWORD=
N8N_WEBHOOK_SECRET=
N8N_API_KEY=

# ── Server ─────────────────────────────────────────────────────
DOMAIN=
ADMIN_EMAIL=
